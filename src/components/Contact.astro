---
import { Image } from 'astro:assets';
import iconCream from '../assets/logo-icon-cream.png';
import { useT, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).contact;
---

<section id="contact" class="section contact">
  <div class="wrap contact-inner" data-reveal>
    <Image src={iconCream} alt="" width={50} height={41} class="contact-mark" aria-hidden="true" />
    <h2 class="display-l contact-title" set:html={t.heading} />
    <p class="contact-sub">{t.sub}</p>
    <div class="contact-actions">
      <a href="tel:+19412506561" class="btn btn-on-pine" data-magnetic>
        <span aria-hidden="true">&#9742;</span> {t.phone}
      </a>
      <a href="mailto:Elizabeth@primarycareandbeyond.com" class="btn btn-ghost-pine">
        {t.email}
      </a>
    </div>
  </div>
</section>

<style>
  .contact { background: var(--color-pine); color: var(--color-cream); text-align: center; }
  .contact-inner { max-width: 42rem; margin: 0 auto; }
  .contact-mark { display: inline-block; margin: 0 auto 1.5rem; opacity: 0.95; }
  .contact-title { color: var(--color-cream); margin: 0; }
  .contact-sub { margin: 1.4rem auto 0; max-width: 34rem; font-size: var(--text-lead); line-height: 1.5; color: color-mix(in srgb, var(--color-cream) 82%, transparent); }
  .contact-actions { margin-top: 2.4rem; display: flex; flex-wrap: wrap; gap: 0.85rem; justify-content: center; }

  @media (max-width: 540px) {
    .contact-actions { flex-direction: column; align-items: stretch; }
    .contact-actions .btn { width: 100%; justify-content: center; white-space: normal; overflow-wrap: anywhere; }
  }
</style>
