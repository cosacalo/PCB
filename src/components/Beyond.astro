---
import { useT, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).care;
const popLabel = lang === 'es' ? 'Qué significa' : 'What this means';
---

<section id="care" class="section care">
  <div class="wrap">
    <header class="care-head" data-reveal>
      <h2 class="display-l care-title">{t.heading}</h2>
      <p class="lead prose care-lead">{t.lead}</p>
    </header>

    <!-- Foundation: primary care, the base. A boxed, elevated card so its
         contents read as one grouped unit and it anchors the section. -->
    <article class="card foundation-card" data-reveal>
      <p class="label card-kicker">{t.foundation.label}</p>
      <h3 class="card-title display-s">{t.foundation.title}</h3>
      <p class="card-body">{t.foundation.body}</p>
      <ul class="path-tags">
        {
          t.foundation.tags.map((tag) => (
            <li>
              <button type="button" class="tag" aria-expanded="false" aria-controls="care-tagpop" data-def={tag.def}>{tag.label}</button>
            </li>
          ))
        }
      </ul>
    </article>

    <!-- And beyond: the deeper methods. The single drawn rule introduces them;
         the two are boxed together as a grouped pair so they clearly belong
         to the practice, never a loose stack and never a footnote. -->
    <div class="beyond-head" data-reveal>
      <span class="rule-draw beyond-rule" aria-hidden="true"></span>
      <p class="label beyond-label">{t.beyondLabel}</p>
      <p class="beyond-lead prose">{t.beyondLead}</p>
    </div>

    <div class="beyond-grid">
      {
        t.beyond.map((m, i) => (
          <article class="card beyond-card" data-reveal style={`transition-delay:${i * 80}ms`}>
            <h3 class="card-title display-s">{m.title}</h3>
            <p class="card-body">{m.body}</p>
            <ul class="path-tags">
              {m.tags.map((tag) => (
                <li>
                  <button type="button" class="tag" aria-expanded="false" aria-controls="care-tagpop" data-def={tag.def}>{tag.label}</button>
                </li>
              ))}
            </ul>
          </article>
        ))
      }
    </div>
  </div>

  <div id="care-tagpop" class="tagpop" role="region" aria-label={popLabel} aria-live="polite" data-open="false">
    <span class="tagpop-arrow" aria-hidden="true"></span>
    <p class="tagpop-text"></p>
  </div>
</section>

<style>
  .care { background: var(--color-cream); }
  .care-head { max-width: 52rem; }
  .care-title { max-width: 20ch; }
  .care-lead { margin-top: 1.3rem; max-width: 46rem; }

  /* Cards are the grouping device: each card's contents (title, body, chips)
     read as one unit, and stay grouped when stacked on mobile. */
  .card {
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    background: color-mix(in srgb, #fff 32%, var(--color-cream));
    padding: clamp(1.85rem, 3.2vw, 2.6rem);
  }
  .card-kicker { margin: 0 0 0.7rem; color: var(--color-sage-deep); }
  .card-title { margin: 0; color: var(--color-pine); }
  .card-body { margin: 0.8rem 0 0; color: var(--color-pine-ink); font-size: var(--text-sm); line-height: 1.6; }

  /* Foundation: full width + elevated, so primary care is the dominant anchor. */
  .foundation-card {
    margin-top: clamp(2.75rem, 6vw, 4.5rem);
    background: color-mix(in srgb, #fff 48%, var(--color-cream));
    box-shadow: var(--shadow-frame);
  }
  .foundation-card .card-body { max-width: 58rem; }

  /* "And beyond" turn: the single drawn rule, then the grouped pair below. */
  .beyond-head { margin: clamp(2.75rem, 5.5vw, 4rem) 0 0; }
  .beyond-rule { width: clamp(3rem, 6vw, 4.5rem); margin-bottom: 1.2rem; }
  .beyond-label { margin: 0; color: var(--color-sage-deep); }
  .beyond-lead { margin: 0.6rem 0 0; max-width: 42rem; color: var(--color-pine-ink); font-size: var(--text-base); line-height: 1.6; }

  /* The beyond pair: two cards, secondary to the foundation (flat, no shadow). */
  .beyond-grid { margin-top: clamp(1.6rem, 3.5vw, 2.4rem); display: grid; grid-template-columns: 1fr; gap: clamp(1.25rem, 3vw, 1.75rem); align-items: start; }

  /* Service chips (tap to reveal a short definition), grouped inside each card. */
  .path-tags { list-style: none; margin: 1.3rem 0 0; padding: 1.3rem 0 0; border-top: 1px solid var(--hair); display: flex; flex-wrap: wrap; gap: 0.45rem; }
  .path-tags li { display: flex; }
  .tag {
    font-family: var(--font-body);
    font-size: 0.78rem;
    font-weight: 600;
    line-height: 1.7;
    color: var(--color-pine);
    background: var(--color-sage-wash);
    border: 0;
    border-radius: 999px;
    padding: 0.3rem 0.7rem;
    margin: 0;
    cursor: pointer;
    transition: background-color var(--dur) var(--ease);
  }
  .tag:hover { background: color-mix(in srgb, var(--color-sage-wash) 78%, var(--color-sage)); }
  .tag:focus-visible { outline: 2px solid var(--color-terracotta); outline-offset: 2px; }
  .tag[aria-expanded='true'] { background: color-mix(in srgb, var(--color-sage-wash) 70%, var(--color-sage)); }

  /* Shared definition popover (fixed, clamps to viewport on mobile). */
  .tagpop {
    position: fixed;
    z-index: 55;
    left: 0;
    top: 0;
    max-width: min(20rem, calc(100vw - 1.5rem));
    background: var(--color-cream);
    color: var(--color-pine-ink);
    border: 1px solid var(--hair-strong);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    padding: 0.8rem 0.9rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 0.15s var(--ease), transform 0.15s var(--ease), visibility 0s linear 0.15s;
  }
  .tagpop[data-open='true'] {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    transition: opacity 0.15s var(--ease), transform 0.15s var(--ease);
  }
  .tagpop-text { margin: 0; font-size: var(--text-sm); line-height: 1.5; }
  .tagpop-arrow { position: absolute; left: 1rem; width: 10px; height: 10px; background: var(--color-cream); border: 1px solid var(--hair-strong); transform: rotate(45deg); }
  .tagpop[data-placement='below'] .tagpop-arrow { top: -6px; border-right: none; border-bottom: none; }
  .tagpop[data-placement='above'] .tagpop-arrow { bottom: -6px; border-left: none; border-top: none; }

  @media (prefers-reduced-motion: reduce) { .tagpop { transition: visibility 0s linear 0s; } }

  @media (min-width: 860px) {
    .beyond-grid { grid-template-columns: 1fr 1fr; gap: clamp(1.5rem, 3vw, 2rem); }
  }
</style>

<script>
  const pop = document.getElementById('care-tagpop');
  const tags = Array.from(document.querySelectorAll('.path-tags .tag'));

  if (pop && tags.length) {
    const text = pop.querySelector('.tagpop-text');
    const arrow = pop.querySelector('.tagpop-arrow');
    let active = null;

    const close = () => {
      if (!active) return;
      active.setAttribute('aria-expanded', 'false');
      active = null;
      pop.setAttribute('data-open', 'false');
      window.setTimeout(() => { if (!active) text.textContent = ''; }, 160);
    };

    const place = (btn) => {
      const r = btn.getBoundingClientRect();
      const pad = 12;
      const gap = 10;
      const pw = pop.offsetWidth;
      const ph = pop.offsetHeight;

      let left = r.left + r.width / 2 - pw / 2;
      left = Math.max(pad, Math.min(left, window.innerWidth - pw - pad));

      let top, placement;
      if (r.bottom + gap + ph <= window.innerHeight - pad) {
        top = r.bottom + gap;
        placement = 'below';
      } else if (r.top - gap - ph >= pad) {
        top = r.top - gap - ph;
        placement = 'above';
      } else {
        top = Math.max(pad, Math.min(r.bottom + gap, window.innerHeight - ph - pad));
        placement = 'below';
      }

      pop.style.left = `${Math.round(left)}px`;
      pop.style.top = `${Math.round(top)}px`;
      pop.setAttribute('data-placement', placement);

      const arrowX = Math.max(10, Math.min(r.left + r.width / 2 - left - 5, pw - 20));
      arrow.style.left = `${Math.round(arrowX)}px`;
    };

    const open = (btn) => {
      text.textContent = btn.getAttribute('data-def') || '';
      pop.setAttribute('data-open', 'true');
      place(btn);
      btn.setAttribute('aria-expanded', 'true');
      active = btn;
    };

    tags.forEach((btn) => {
      btn.addEventListener('click', (e) => {
        e.stopPropagation();
        if (active === btn) { close(); return; }
        if (active) active.setAttribute('aria-expanded', 'false');
        open(btn);
      });
    });

    document.addEventListener('click', (e) => {
      if (active && !pop.contains(e.target)) close();
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && active) { const b = active; close(); b.focus(); }
    });
    window.addEventListener('scroll', () => { if (active) close(); }, { passive: true });
    window.addEventListener('resize', () => { if (active) close(); });
  }
</script>
