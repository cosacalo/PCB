---
// Validating, warm, not confrontational. The lines below are paraphrased from
// voice-of-customer research (copy.md), framed inclusively (not women-only) as
// what patients often hear. NOT testimonials from this practice's patients.
const lines = [
  'Your labs are normal.',
  'It is probably stress.',
  'It is probably your age.',
  'Try eating less and moving more.',
  'Let’s just see how you feel.',
];
---

<section id="heard" class="section empathy">
  <div class="wrap empathy-grid">
    <div class="empathy-head" data-reveal>
      <h2 class="display-l empathy-title">You know when something feels off.</h2>
      <p class="empathy-body">
        Maybe your labs looked normal, but you still felt tired, foggy, uncomfortable, or
        unlike yourself. Maybe you were told to wait, manage stress, lose weight, or try one
        more prescription.
      </p>
      <p class="empathy-body">
        At Primary Care and Beyond, you get time to talk through the full picture and decide
        what kind of care makes sense next.
      </p>
      <p class="empathy-strong">You are not here for a rushed answer. You are here to be heard.</p>
      <a href="#care" class="link empathy-link">See how care works <span class="arr" aria-hidden="true">&rarr;</span></a>
    </div>

    <div class="empathy-aside" data-reveal>
      <p class="empathy-frame">Things patients often hear before they find deeper care</p>
      <ul class="lines" aria-label="Phrases patients report being told by other providers">
        {lines.map((d) => <li>&ldquo;{d}&rdquo;</li>)}
      </ul>
    </div>
  </div>
</section>

<style>
  .empathy { background: var(--color-cream-soft); }
  .empathy-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4.5rem);
    align-items: start;
  }
  .empathy-head { max-width: 36rem; }
  .empathy-title { color: var(--color-pine-deep); max-width: 15ch; }
  .empathy-body { margin: 1.4rem 0 0; max-width: 42ch; font-size: var(--text-lead); line-height: 1.5; color: var(--color-pine-ink); }
  .empathy-body + .empathy-body { margin-top: 1rem; font-size: var(--text-base); }
  .empathy-strong {
    margin: 1.3rem 0 0;
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: var(--display-s);
    line-height: 1.25;
    color: var(--color-pine);
    max-width: 26ch;
  }
  .empathy-link { margin-top: 1.8rem; }

  .empathy-frame { margin: 0 0 1.4rem; font-size: var(--text-sm); font-weight: 600; color: var(--color-sage-deep); }
  /* Warm, soft strike-through: relief, not confrontation */
  .lines { list-style: none; margin: 0; padding: 0; display: grid; gap: 1rem; }
  .lines li {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--display-s);
    line-height: 1.3;
    color: color-mix(in srgb, var(--color-pine-ink) 80%, var(--color-cream-soft));
    padding-left: 1.2rem;
    border-left: 2px solid color-mix(in srgb, var(--color-sage) 60%, transparent);
    text-decoration: line-through;
    text-decoration-color: color-mix(in srgb, var(--color-tan) 75%, transparent);
    text-decoration-thickness: 1.5px;
  }

  @media (min-width: 900px) {
    .empathy-grid { grid-template-columns: 1.05fr 0.95fr; gap: clamp(3rem, 6vw, 5.5rem); }
    .empathy-aside { padding-top: 0.4rem; }
  }
</style>
