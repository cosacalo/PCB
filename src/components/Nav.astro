---
import { Image } from 'astro:assets';
import icon from '../assets/logo-icon.png';
import { useT, otherLang, routes, bookRoutes, type Lang } from '../i18n';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).nav;
const otherHref = routes[otherLang(lang)];
const bookHref = bookRoutes[lang];
---

<nav id="site-nav" class="site-nav">
  <div class="nav-inner">
    <a href="#top" class="nav-brand" aria-label="Primary Care and Beyond, home">
      <Image src={icon} alt="" widths={[56, 112]} class="nav-icon" loading="eager" aria-hidden="true" />
      <span class="nav-wordmark">
        <span class="nav-name">Primary Care</span>
        <span class="nav-sub">and Beyond</span>
      </span>
    </a>

    <ul class="nav-links">
      {t.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>

    <div class="nav-right">
      <a class="nav-lang" href={otherHref} hreflang={otherLang(lang)} aria-label={t.toggleAria}>{t.toggle}</a>

      <a href="tel:+19413903224" class="btn btn-outline nav-cta">
        <span aria-hidden="true">&#9742;</span> {t.cta}
      </a>

      <a href={bookHref} class="btn btn-primary nav-book-cta">{t.book}</a>

      <details class="nav-menu" id="nav-menu">
        <summary class="nav-toggle" aria-label="Menu">
          <span class="nav-burger" aria-hidden="true"></span>
        </summary>
        <div class="nav-sheet">
          <ul>
            {t.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
          </ul>
          <a href={bookHref} class="btn btn-primary nav-sheet-cta">{t.book}</a>
          <a href="tel:+19413903224" class="btn btn-outline nav-sheet-book">
            <span aria-hidden="true">&#9742;</span> {t.cta}
          </a>
        </div>
      </details>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-cream) 85%, transparent);
    backdrop-filter: saturate(1.05) blur(12px);
    -webkit-backdrop-filter: saturate(1.05) blur(12px);
    border-bottom: 1px solid transparent;
    transition: background-color 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
      border-color 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
      backdrop-filter 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
  }
  /* Base + mobile: stays a full-width frosted bar on scroll. */
  .site-nav.is-scrolled {
    border-bottom-color: var(--hair);
    background: color-mix(in srgb, var(--color-cream) 93%, transparent);
    box-shadow: 0 1px 2px rgba(30, 39, 22, 0.06);
  }
  .nav-inner {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0.7rem clamp(1.35rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
    border: 1px solid transparent;
    transition: max-width 0.7s cubic-bezier(0.22, 0.61, 0.36, 1),
      padding 0.7s cubic-bezier(0.22, 0.61, 0.36, 1),
      background-color 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
      border-color 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
      border-radius 0.6s cubic-bezier(0.22, 0.61, 0.36, 1),
      box-shadow 0.6s cubic-bezier(0.22, 0.61, 0.36, 1);
  }

  /* Desktop: contract into a pinned, rounded, frosted bar. Ported from the
     experiment spec, mapped to our cream palette + pine hairline; the nav stays
     sticky so it pins flush at the top with no offset, and the side gaps appear
     as the inner narrows (1200px -> 1120px) while the outer clears. */
  @media (min-width: 768px) {
    .site-nav.is-scrolled {
      background-color: transparent;
      box-shadow: none;
      backdrop-filter: none;
      -webkit-backdrop-filter: none;
      border-bottom-color: transparent;
    }
    .site-nav.is-scrolled .nav-inner {
      max-width: 70rem;
      padding-block: 0.5rem;
      padding-inline: 1.5rem;
      background: color-mix(in srgb, var(--color-cream) 92%, transparent);
      backdrop-filter: blur(12px) saturate(140%);
      -webkit-backdrop-filter: blur(12px) saturate(140%);
      border-color: var(--hair-strong);
      border-radius: 0 0 8px 8px;
      box-shadow: 0 1px 2px rgba(30, 39, 22, 0.06), 0 8px 24px rgba(30, 39, 22, 0.08);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .site-nav, .nav-inner { transition: none; }
  }

  .nav-brand { display: inline-flex; align-items: center; gap: 0.65rem; text-decoration: none; flex: 0 0 auto; }
  /* `.anim-ready .nav-brand { opacity: 0 }` lives in global.css: the intro flies
     a twin lockup into this spot, then reveals it. It must be global because
     scoped styles can't target the `.anim-ready` class on <html>. */
  .nav-icon { height: 2.7rem; width: auto; transition: height var(--dur) var(--ease); }
  .is-scrolled .nav-icon { height: 2.4rem; }
  .nav-wordmark { display: flex; flex-direction: column; line-height: 0.94; }
  .nav-name { font-family: var(--font-display); font-weight: 600; font-size: 1.4rem; color: var(--color-pine); }
  .nav-sub { font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1rem; color: var(--color-terracotta-deep); }

  .nav-links { display: none; gap: 2rem; list-style: none; margin: 0; padding: 0; }
  .nav-links a { font-weight: 500; font-size: 0.95rem; color: var(--color-pine-ink); text-decoration: none; position: relative; padding-bottom: 2px; }
  .nav-links a::after { content: ''; position: absolute; left: 0; bottom: 0; height: 1px; width: 0; background: var(--color-terracotta); transition: width 0.2s var(--ease); }
  .nav-links a:hover { color: var(--color-pine); }
  .nav-links a:hover::after { width: 100%; }

  .nav-right { display: flex; align-items: center; gap: 0.6rem; }
  /* Bar action buttons (outline Call + filled Book) are desktop-only; on mobile
     they live in the menu sheet so the bar has room for the language toggle. */
  .nav-cta, .nav-book-cta {
    display: none;
    padding: 0.55rem 1.05rem;
    font-size: 0.9rem;
    min-height: 2.75rem;
  }
  .nav-sheet-cta, .nav-sheet-book { width: 100%; justify-content: center; margin-top: 0.5rem; }

  /* Language toggle: a quiet pill in the bar, visible on every breakpoint. */
  .nav-lang {
    display: inline-flex;
    align-items: center;
    min-height: 2.75rem;
    padding: 0 0.85rem;
    border: 1px solid var(--hair-strong);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-pine);
    text-decoration: none;
    white-space: nowrap;
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .nav-lang:hover { border-color: var(--color-pine); background: color-mix(in srgb, var(--color-pine) 5%, transparent); }

  /* Mobile menu */
  .nav-menu { position: relative; }
  .nav-toggle {
    list-style: none;
    cursor: pointer;
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--hair-strong);
  }
  .nav-toggle::-webkit-details-marker { display: none; }
  .nav-toggle:focus-visible { outline: 2px solid var(--color-terracotta); outline-offset: 3px; }
  .nav-burger, .nav-burger::before, .nav-burger::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-pine);
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .nav-burger { position: relative; }
  .nav-burger::before { position: absolute; top: -6px; left: 0; }
  .nav-burger::after { position: absolute; top: 6px; left: 0; }
  .nav-menu[open] .nav-burger { background: transparent; }
  .nav-menu[open] .nav-burger::before { transform: translateY(6px) rotate(45deg); }
  .nav-menu[open] .nav-burger::after { transform: translateY(-6px) rotate(-45deg); }

  .nav-sheet {
    position: absolute;
    top: calc(100% + 0.7rem);
    right: 0;
    min-width: 14rem;
    background: var(--color-cream);
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    padding: 0.5rem;
  }
  .nav-sheet ul { list-style: none; margin: 0; padding: 0; display: grid; }
  .nav-sheet ul a { display: block; padding: 0.8rem 0.9rem; border-radius: 3px; font-weight: 600; color: var(--color-pine); text-decoration: none; }
  .nav-sheet ul a:hover { background: var(--color-sage-wash); }

  @media (max-width: 420px) { .nav-sub { display: none; } .nav-name { font-size: 1.25rem; } }
  @media (min-width: 900px) {
    .nav-links { display: flex; }
    .nav-cta, .nav-book-cta { display: inline-flex; }
    .nav-menu { display: none; }
  }
</style>
