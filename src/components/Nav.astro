---
import { Image } from 'astro:assets';
import icon from '../assets/logo-icon.png';
import { useT, otherLang, routes, type Lang } from '../i18n';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).nav;
const otherHref = routes[otherLang(lang)];
---

<nav id="site-nav" class="site-nav">
  <div class="nav-inner">
    <a href="#top" class="nav-brand" aria-label="Primary Care and Beyond, home">
      <Image src={icon} alt="" widths={[56, 112]} class="nav-icon" loading="eager" aria-hidden="true" />
      <span class="nav-wordmark">
        <span class="nav-name">Primary Care</span>
        <span class="nav-sub">and Beyond</span>
      </span>
    </a>

    <ul class="nav-links">
      {t.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
    </ul>

    <div class="nav-right">
      <a class="nav-lang" href={otherHref} hreflang={otherLang(lang)} aria-label={t.toggleAria}>{t.toggle}</a>

      <a href="tel:+19412506561" class="btn btn-primary nav-cta">
        <span aria-hidden="true">&#9742;</span> {t.cta}
      </a>

      <details class="nav-menu" id="nav-menu">
        <summary class="nav-toggle" aria-label="Menu">
          <span class="nav-burger" aria-hidden="true"></span>
        </summary>
        <div class="nav-sheet">
          <ul>
            {t.links.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
          </ul>
          <a class="nav-sheet-lang" href={otherHref} hreflang={otherLang(lang)} aria-label={t.toggleAria}>{t.toggle}</a>
        </div>
      </details>
    </div>
  </div>
</nav>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 40;
    background: color-mix(in srgb, var(--color-cream) 85%, transparent);
    backdrop-filter: saturate(1.05) blur(12px);
    border-bottom: 1px solid transparent;
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .site-nav.is-scrolled { border-bottom-color: var(--hair); background: color-mix(in srgb, var(--color-cream) 93%, transparent); }
  .nav-inner {
    max-width: 75rem;
    margin: 0 auto;
    padding: 0.7rem clamp(1.35rem, 4vw, 2.5rem);
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.25rem;
  }

  .nav-brand { display: inline-flex; align-items: center; gap: 0.65rem; text-decoration: none; flex: 0 0 auto; }
  .nav-icon { height: 2.7rem; width: auto; transition: height var(--dur) var(--ease); }
  .is-scrolled .nav-icon { height: 2.4rem; }
  .nav-wordmark { display: flex; flex-direction: column; line-height: 0.94; }
  .nav-name { font-family: var(--font-display); font-weight: 600; font-size: 1.4rem; color: var(--color-pine); }
  .nav-sub { font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1rem; color: var(--color-terracotta-deep); }

  .nav-links { display: none; gap: 2rem; list-style: none; margin: 0; padding: 0; }
  .nav-links a { font-weight: 500; font-size: 0.95rem; color: var(--color-pine-ink); text-decoration: none; position: relative; padding-bottom: 2px; }
  .nav-links a::after { content: ''; position: absolute; left: 0; bottom: 0; height: 1px; width: 0; background: var(--color-terracotta); transition: width 0.2s var(--ease); }
  .nav-links a:hover { color: var(--color-pine); }
  .nav-links a:hover::after { width: 100%; }

  .nav-right { display: flex; align-items: center; gap: 0.6rem; }
  .nav-cta { padding: 0.58rem 1.1rem; font-size: 0.9rem; min-height: 2.75rem; }

  /* Language toggle: quiet pill in the bar (desktop), and as a row in the sheet (mobile) */
  .nav-lang {
    display: none;
    align-items: center;
    min-height: 2.75rem;
    padding: 0 0.85rem;
    border: 1px solid var(--hair-strong);
    border-radius: 999px;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    color: var(--color-pine);
    text-decoration: none;
    transition: border-color var(--dur) var(--ease), background-color var(--dur) var(--ease);
  }
  .nav-lang:hover { border-color: var(--color-pine); background: color-mix(in srgb, var(--color-pine) 5%, transparent); }

  /* Mobile menu */
  .nav-menu { position: relative; }
  .nav-toggle {
    list-style: none;
    cursor: pointer;
    display: inline-grid;
    place-items: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: var(--radius);
    border: 1px solid var(--hair-strong);
  }
  .nav-toggle::-webkit-details-marker { display: none; }
  .nav-toggle:focus-visible { outline: 2px solid var(--color-terracotta); outline-offset: 3px; }
  .nav-burger, .nav-burger::before, .nav-burger::after {
    content: '';
    display: block;
    width: 18px;
    height: 2px;
    background: var(--color-pine);
    transition: transform var(--dur) var(--ease), opacity var(--dur) var(--ease);
  }
  .nav-burger { position: relative; }
  .nav-burger::before { position: absolute; top: -6px; left: 0; }
  .nav-burger::after { position: absolute; top: 6px; left: 0; }
  .nav-menu[open] .nav-burger { background: transparent; }
  .nav-menu[open] .nav-burger::before { transform: translateY(6px) rotate(45deg); }
  .nav-menu[open] .nav-burger::after { transform: translateY(-6px) rotate(-45deg); }

  .nav-sheet {
    position: absolute;
    top: calc(100% + 0.7rem);
    right: 0;
    min-width: 14rem;
    background: var(--color-cream);
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    padding: 0.5rem;
  }
  .nav-sheet ul { list-style: none; margin: 0; padding: 0; display: grid; }
  .nav-sheet a { display: block; padding: 0.8rem 0.9rem; border-radius: 3px; font-weight: 600; color: var(--color-pine); text-decoration: none; }
  .nav-sheet a:hover { background: var(--color-sage-wash); }
  .nav-sheet-lang { margin-top: 0.3rem; border-top: 1px solid var(--hair); color: var(--color-terracotta-deep) !important; }

  @media (max-width: 420px) { .nav-sub { display: none; } .nav-name { font-size: 1.25rem; } }
  @media (min-width: 900px) {
    .nav-links { display: flex; }
    .nav-lang { display: inline-flex; }
    .nav-menu { display: none; }
  }
</style>
