---
import { useT, bookRoutes, type Lang } from '../i18n';
import logoSvg from '../assets/logo-icon.svg?raw';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).hero;
const tNav = useT(lang).nav;
const bookHref = bookRoutes[lang];
---

<header id="top" class="hero" data-hero>
  <div class="atmos" aria-hidden="true">
    <span class="blob blob-1"></span>
    <span class="blob blob-2"></span>
    <span class="blob blob-3"></span>
  </div>

  <div class="wrap hero-inner">
    <div class="hero-copy">
      <p class="label hero-kicker" data-hero-kicker>{t.kicker}</p>

      <h1 class="hero-title reveal-lines">
        {t.headlineLines.map((line) => (
          <span class="line"><span set:html={line} /></span>
        ))}
      </h1>

      <span class="hero-rule rule-draw" data-hero-rule aria-hidden="true"></span>

      <p class="hero-sub" data-hero-sub>{t.sub}</p>

      <div class="hero-actions" data-hero-cta>
        <a href={bookHref} class="btn btn-primary" data-magnetic>{tNav.book}</a>
        <a href="tel:+19413903224" class="btn btn-outline">
          <span aria-hidden="true">&#9742;</span> {t.call}
        </a>
        <a href="mailto:Elizabeth@primarycareandbeyond.com" class="link">
          {t.email} <span class="arr" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</header>

<!--
  Brand intro: the logo assembles in open space (icon draws in, the name swoops
  in from the right), then the whole lockup flies up and shrinks to become the
  nav logo while the hero content takes its place. The lockup is built LARGE so
  the on-screen entrance renders at native resolution (crisp); the closing
  flight scales it DOWN onto the real nav logo. Runs once on load; skipped
  entirely for no-JS / reduced-motion (gated by `.anim-ready`).
-->
<div class="brand-intro" data-brand-intro aria-hidden="true">
  <div class="brand-intro-lockup" data-intro-lockup>
    <span class="brand-intro-icon" data-intro-icon><Fragment set:html={logoSvg} /></span>
    <span class="brand-intro-word" data-intro-word>
      <span class="brand-intro-name">Primary Care</span>
      <span class="brand-intro-sub">and Beyond</span>
    </span>
  </div>
</div>

<style>
  .hero { position: relative; overflow: hidden; background: var(--color-cream); }

  /* Living atmosphere: the soft green-hint wash from the prior hero. */
  .atmos { position: absolute; inset: 0; z-index: 0; overflow: hidden; }
  .blob { position: absolute; border-radius: 999px; filter: blur(70px); opacity: 0.55; }
  .blob-1 { width: 46vw; height: 46vw; right: -8vw; top: -10vw; background: var(--color-sage-wash); }
  .blob-2 { width: 32vw; height: 32vw; right: 18vw; top: 24vw; background: color-mix(in srgb, var(--color-terracotta) 22%, transparent); opacity: 0.35; }
  .blob-3 { width: 38vw; height: 38vw; left: -12vw; bottom: -14vw; background: color-mix(in srgb, var(--color-sage) 28%, transparent); }
  @media (prefers-reduced-motion: no-preference) {
    .blob-1 { animation: drift1 22s ease-in-out infinite alternate; }
    .blob-2 { animation: drift2 28s ease-in-out infinite alternate; }
    .blob-3 { animation: drift3 26s ease-in-out infinite alternate; }
  }
  @keyframes drift1 { to { transform: translate3d(-4vw, 4vw, 0) scale(1.08); } }
  @keyframes drift2 { to { transform: translate3d(3vw, -3vw, 0) scale(1.12); } }
  @keyframes drift3 { to { transform: translate3d(5vw, -3vw, 0) scale(1.06); } }

  .hero-inner {
    position: relative;
    z-index: 2;
    min-height: min(84vh, 48rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: clamp(3.5rem, 7vw, 6rem);
    padding-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .hero-copy { max-width: 54rem; }

  .hero-kicker { margin: 0 0 clamp(1.4rem, 3vw, 2rem); }

  .hero-title {
    margin: 0;
    max-width: 24ch;
    color: var(--color-pine-deep);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.6rem, 1.5rem + 4.6vw, 5.4rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .hero-title :global(em) { font-style: italic; font-weight: 500; color: var(--color-pine); }

  .hero-rule { width: clamp(4rem, 8vw, 6.5rem); margin-top: clamp(1.4rem, 3vw, 2rem); }

  .hero-sub {
    margin: clamp(1.4rem, 3vw, 2rem) 0 0;
    max-width: 38rem;
    font-size: var(--text-lead);
    line-height: 1.5;
    color: var(--color-pine-ink);
  }

  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.4rem; margin-top: clamp(1.9rem, 4vw, 2.5rem); }

  @media (max-width: 560px) {
    .hero-title { font-size: clamp(2.1rem, 8.5vw, 2.9rem); line-height: 1.04; max-width: 16ch; }
  }

  /* --------------------------------------------------------------------------
     Brand intro overlay. Built LARGE (native resolution = crisp), then scaled
     DOWN onto the real nav logo by the timeline. The `.anim-ready` entrance /
     hand-off states live in global.css (scoped styles can't target the
     `.anim-ready` class on <html>).
  -------------------------------------------------------------------------- */
  .brand-intro {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: none;
    place-items: center;
    pointer-events: none;
  }

  .brand-intro-lockup {
    display: inline-flex;
    align-items: center;
    gap: clamp(0.7rem, 1.8vw, 1.15rem);
    transform-origin: 50% 50%;
    will-change: transform;
  }

  .brand-intro-icon { display: inline-flex; }
  .brand-intro-icon :global(.pcb-mark) {
    display: block;
    height: clamp(4.5rem, 9vw, 7.5rem);
    width: auto;
    overflow: visible;
  }

  .brand-intro-word { display: flex; flex-direction: column; line-height: 0.94; }
  .brand-intro-name { font-family: var(--font-display); font-weight: 600; font-size: clamp(2rem, 4.4vw, 3.4rem); color: var(--color-pine); }
  .brand-intro-sub { font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: clamp(1.35rem, 3vw, 2.2rem); color: var(--color-terracotta-deep); }

  @media (max-width: 420px) {
    .brand-intro-sub { display: none; }
  }
</style>
