---
// Editorial manifesto hero, type-led and asymmetric. Four elements: kicker,
// headline, subhead, CTAs. No scroll cue, no boxed panel. (The optional
// service sub-line was left off to keep the hero a single clean moment; the
// three paths are spelled out immediately below in the Care section.)
---

<header id="top" class="hero" data-hero>
  <div class="hero-bloom" aria-hidden="true"></div>

  <div class="wrap hero-inner">
    <p class="label hero-kicker" data-hero-kicker>Telehealth care for adults in Florida</p>

    <h1 class="hero-title reveal-lines">
      <span class="line"><span>Primary care with time</span></span>
      <span class="line"><span>to go <em>beyond the basics.</em></span></span>
    </h1>

    <span class="hero-rule rule-draw" data-hero-rule aria-hidden="true"></span>

    <p class="hero-sub" data-hero-sub>
      Work with one Florida nurse practitioner who has time to listen, understand your history,
      and look deeper when your symptoms need more than a rushed visit.
    </p>

    <div class="hero-actions" data-hero-cta>
      <a href="tel:+19412506561" class="btn btn-primary" data-magnetic>
        <span aria-hidden="true">&#9742;</span> Call 941.250.6561
      </a>
      <a href="mailto:Elizabeth@primarycareandbeyond.com" class="link">
        Email Liz <span class="arr" aria-hidden="true">&rarr;</span>
      </a>
    </div>
  </div>
</header>

<style>
  .hero { position: relative; overflow: hidden; background: var(--color-cream); }

  .hero-bloom {
    position: absolute;
    top: -30vh;
    right: -16vw;
    width: 68vw;
    height: 68vw;
    max-width: 58rem;
    max-height: 58rem;
    z-index: 0;
    pointer-events: none;
    background: radial-gradient(
      circle at center,
      color-mix(in srgb, var(--color-sage) 26%, transparent) 0%,
      color-mix(in srgb, var(--color-sage-wash) 50%, transparent) 40%,
      transparent 68%
    );
  }

  .hero-inner {
    position: relative;
    z-index: 2;
    min-height: min(90vh, 52rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding-top: clamp(3.5rem, 7vw, 6rem);
    padding-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .hero-kicker { margin: 0 0 clamp(1.4rem, 3vw, 2rem); }

  /* Headline is 8 words, so the scale is moderated (per hero font-scale rule) */
  .hero-title {
    margin: 0;
    max-width: 20ch;
    color: var(--color-pine-deep);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.5rem, 1.8rem + 3.6vw, 4.6rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .hero-title em { font-style: italic; font-weight: 500; color: var(--color-pine); }

  .hero-rule { width: clamp(4rem, 8vw, 6.5rem); margin-top: clamp(1.4rem, 3vw, 2rem); }

  .hero-sub {
    margin: clamp(1.4rem, 3vw, 2rem) 0 0;
    max-width: 36rem;
    font-size: var(--text-lead);
    line-height: 1.5;
    color: var(--color-pine-ink);
  }

  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.4rem; margin-top: clamp(1.9rem, 4vw, 2.5rem); }

  @media (max-width: 560px) {
    .hero-title { font-size: clamp(2.1rem, 8.5vw, 2.8rem); line-height: 1.03; max-width: 16ch; }
  }
</style>
