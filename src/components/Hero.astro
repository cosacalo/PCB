---
import { useT, type Lang } from '../i18n';
import logoSvg from '../assets/logo-icon.svg?raw';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).hero;
---

<header id="top" class="hero" data-hero>
  <div class="wrap hero-inner">
    <div class="hero-copy">
      <p class="label hero-kicker" data-hero-kicker>{t.kicker}</p>

      <h1 class="hero-title reveal-lines">
        {t.headlineLines.map((line) => (
          <span class="line"><span set:html={line} /></span>
        ))}
      </h1>

      <span class="hero-rule rule-draw" data-hero-rule aria-hidden="true"></span>

      <p class="hero-sub" data-hero-sub>{t.sub}</p>

      <div class="hero-actions" data-hero-cta>
        <a href="tel:+19412506561" class="btn btn-primary" data-magnetic>
          <span aria-hidden="true">&#9742;</span> {t.call}
        </a>
        <a href="mailto:Elizabeth@primarycareandbeyond.com" class="link">
          {t.email} <span class="arr" aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>

    <div class="hero-figure" aria-hidden="true" data-hero-logo>
      <div class="hero-logo-tilt"><Fragment set:html={logoSvg} /></div>
    </div>
  </div>
</header>

<style>
  .hero { position: relative; overflow: hidden; background: var(--color-cream); }

  .hero-inner {
    position: relative;
    z-index: 2;
    min-height: min(90vh, 52rem);
    display: grid;
    grid-template-columns: 1fr;
    align-items: center;
    gap: clamp(2rem, 5vw, 4rem);
    padding-top: clamp(3.5rem, 7vw, 6rem);
    padding-bottom: clamp(3.5rem, 7vw, 6rem);
  }

  .hero-kicker { margin: 0 0 clamp(1.4rem, 3vw, 2rem); }

  .hero-title {
    margin: 0;
    max-width: 20ch;
    color: var(--color-pine-deep);
    font-family: var(--font-display);
    font-weight: 500;
    font-size: clamp(2.5rem, 1.8rem + 3.6vw, 4.6rem);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .hero-title :global(em) { font-style: italic; font-weight: 500; color: var(--color-pine); }

  .hero-rule { width: clamp(4rem, 8vw, 6.5rem); margin-top: clamp(1.4rem, 3vw, 2rem); }

  .hero-sub {
    margin: clamp(1.4rem, 3vw, 2rem) 0 0;
    max-width: 36rem;
    font-size: var(--text-lead);
    line-height: 1.5;
    color: var(--color-pine-ink);
  }

  .hero-actions { display: flex; flex-wrap: wrap; align-items: center; gap: 1.4rem; margin-top: clamp(1.9rem, 4vw, 2.5rem); }

  /* The living logo mark (hidden on small screens; the hero is type-led there) */
  .hero-figure { display: none; }

  .hero-logo-tilt { position: relative; z-index: 1; will-change: transform; transform-style: preserve-3d; }
  .hero-figure :global(.pcb-mark) {
    display: block;
    width: 100%;
    height: auto;
    overflow: visible;
    filter: drop-shadow(0 8px 18px color-mix(in srgb, var(--color-pine) 10%, transparent));
  }

  @media (prefers-reduced-motion: no-preference) {
    .hero-figure :global(.pcb-mark) { animation: pcb-breathe 7s var(--ease) infinite alternate; transform-origin: 50% 60%; }
  }
  @keyframes pcb-breathe {
    from { transform: translateY(0) scale(1); }
    to { transform: translateY(-8px) scale(1.035); }
  }

  @media (min-width: 980px) {
    .hero-inner { grid-template-columns: 1.05fr 0.95fr; }
    .hero-figure {
      display: grid;
      place-items: center;
      position: relative;
      justify-self: end;
      width: 100%;
      max-width: 26rem;
      perspective: 900px;
    }
  }

  @media (max-width: 560px) {
    .hero-title { font-size: clamp(2.1rem, 8.5vw, 2.8rem); line-height: 1.03; max-width: 16ch; }
  }
</style>
