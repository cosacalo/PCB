---
import { useT, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).pricing;
const tel = '+19412506561';
---

<section id="pricing" class="section pricing">
  <div class="wrap">
    <header class="pricing-head" data-reveal>
      <p class="label">{t.label}</p>
      <h2 class="display-l pricing-title" set:html={t.headingHtml} />
      <p class="lead prose pricing-lead">{t.lead}</p>
    </header>

    <div class="pricing-body">
      <!-- FOUNDATION: the single anchor. Primary care is the base. -->
      <article class="membership" data-reveal>
        <p class="label membership-label">{t.foundationLabel}</p>
        <h3 class="membership-name display-s">{t.membershipLabel}</h3>
        <p class="price"><span class="price-amt">{t.price}</span><span class="price-per">{t.per}</span></p>
        <p class="price-tag">{t.tag}</p>

        <ul class="incl">
          {
            t.included.map((it) => (
              <li>
                <svg class="tick" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="m5 10.5 3.2 3L15 6.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{it}</span>
              </li>
            ))
          }
        </ul>

        <p class="membership-foot">{t.membershipFoot}</p>
        <a href={`tel:${tel}`} class="btn btn-primary membership-cta">
          <span aria-hidden="true">&#9742;</span> {t.cta}
        </a>
        <p class="bundle-note">{t.bundleNote}</p>
      </article>

      <!-- AND BEYOND: the deeper methods, editorial, subordinate but never a footnote. -->
      <div class="beyond" data-reveal>
        <div class="beyond-head">
          <span class="rule-draw beyond-rule" aria-hidden="true"></span>
          <p class="label beyond-label">{t.beyondLabel}</p>
          <p class="beyond-lead">{t.beyondLead}</p>
        </div>

        <article class="bcol">
          <div class="bcol-head">
            <h3 class="bcol-title display-s">{t.weightTitle}</h3>
            <p class="bprice"><span class="bprice-amt">{t.weightPrice}</span><span class="bprice-per">{t.weightPer}</span></p>
          </div>
          <p class="bcol-body">{t.weightBody}</p>
          <p class="bcol-cross">{t.weightBundle}</p>
          <a href={`tel:${tel}`} class="link bcol-cta">{t.weightCta} <span class="arr" aria-hidden="true">&rarr;</span></a>
        </article>

        <article class="bcol">
          <div class="bcol-head">
            <h3 class="bcol-title display-s">{t.fmTitle}</h3>
            <p class="bprice"><span class="bprice-per bprice-per--solo">{t.fmPer}</span></p>
          </div>
          <p class="bcol-body">{t.fmIntro}</p>
          <ul class="rate-list">
            {
              t.rates.map((r) => (
                <li class="rate">
                  <span class="rate-name">{r.name}<em>{r.detail}</em></span>
                  <span class="rate-price">{r.price}</span>
                </li>
              ))
            }
          </ul>
          <a href={`tel:${tel}`} class="link bcol-cta">{t.fmCta} <span class="arr" aria-hidden="true">&rarr;</span></a>
        </article>
      </div>
    </div>

    <p class="promise" data-reveal set:html={t.promiseHtml} />
  </div>
</section>

<style>
  .pricing { background: var(--color-cream); }
  .pricing-head { max-width: 50rem; }
  .pricing-title { margin: 1.1rem 0 0; }
  .pricing-title :global(em) { font-style: italic; color: var(--color-terracotta-deep); }
  .pricing-lead { margin-top: 1.3rem; max-width: 44rem; }

  .pricing-body {
    margin-top: clamp(2.75rem, 6vw, 4.5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 3.5rem);
    align-items: start;
  }

  /* FOUNDATION: one filled card, the single anchor. */
  .membership {
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    background: color-mix(in srgb, #fff 45%, var(--color-cream));
    padding: clamp(2rem, 4vw, 2.85rem);
  }
  .membership-label { color: var(--color-sage-deep); }
  .membership-name { margin: 0.5rem 0 0; color: var(--color-pine); }
  .price { margin: 0.9rem 0 0; display: flex; align-items: baseline; gap: 0.5rem; }
  .price-amt { font-family: var(--font-display); font-weight: 500; font-size: clamp(3.5rem, 7vw, 5rem); line-height: 0.9; color: var(--color-pine); font-variant-numeric: lining-nums tabular-nums; letter-spacing: -0.02em; }
  .price-per { font-size: 1.05rem; color: var(--color-pine-ink); }
  .price-tag { margin: 0.45rem 0 0; color: var(--color-pine-ink); }

  .incl { list-style: none; margin: 1.75rem 0 0; padding: 1.75rem 0 0; border-top: 1px solid var(--hair); display: grid; gap: 0.8rem; }
  .incl li { display: flex; gap: 0.7rem; align-items: flex-start; color: var(--color-pine-ink); font-size: var(--text-sm); }
  .tick { width: 1.15rem; height: 1.15rem; flex: 0 0 auto; color: var(--color-terracotta); margin-top: 0.15rem; }

  .membership-foot { margin: 1.5rem 0 0; font-size: var(--text-sm); color: var(--color-pine-ink); opacity: 0.85; line-height: 1.6; }
  .membership-cta { margin-top: 1.4rem; width: 100%; justify-content: center; }
  .bundle-note { margin: 1rem 0 0; font-size: var(--text-sm); color: var(--color-terracotta-deep); font-weight: 600; text-align: center; }

  /* AND BEYOND: editorial column, no boxes. */
  .beyond { display: flex; flex-direction: column; }
  .beyond-head { margin-bottom: 0.4rem; }
  .beyond-rule { width: clamp(3rem, 6vw, 4.5rem); margin-bottom: 1.1rem; }
  .beyond-label { color: var(--color-sage-deep); }
  .beyond-lead { margin: 0.55rem 0 0; font-size: var(--text-base); line-height: 1.6; color: var(--color-pine-ink); max-width: 38rem; }

  .bcol { margin-top: clamp(1.8rem, 3.2vw, 2.4rem); padding-top: 1.5rem; border-top: 1px solid var(--hair); display: flex; flex-direction: column; }
  .bcol-head { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; flex-wrap: wrap; }
  .bcol-title { margin: 0; color: var(--color-pine); }
  .bprice { margin: 0; display: flex; align-items: baseline; gap: 0.4rem; white-space: nowrap; }
  .bprice-amt { font-family: var(--font-display); font-weight: 500; font-size: clamp(2rem, 3.4vw, 2.6rem); line-height: 1; color: var(--color-pine); font-variant-numeric: lining-nums tabular-nums; }
  .bprice-per { font-size: var(--text-sm); color: var(--color-pine-ink); }
  .bprice-per--solo { font-weight: 600; color: var(--color-sage-deep); }
  .bcol-body { margin: 0.85rem 0 0; color: var(--color-pine-ink); font-size: var(--text-sm); line-height: 1.6; }
  .bcol-cross { margin: 0.9rem 0 0; font-size: var(--text-sm); color: var(--color-terracotta-deep); font-weight: 600; }

  .rate-list { list-style: none; margin: 1.2rem 0 0; padding: 0; }
  .rate { display: flex; justify-content: space-between; align-items: baseline; gap: 1.5rem; padding: 0.85rem 0; border-bottom: 1px solid var(--hair); }
  .rate-name { display: flex; flex-direction: column; font-weight: 600; color: var(--color-pine); }
  .rate-name em { font-style: normal; font-weight: 400; font-size: var(--text-sm); color: var(--color-pine-ink); opacity: 0.75; margin-top: 0.15rem; }
  .rate-price { font-family: var(--font-display); font-weight: 500; font-size: 1.6rem; color: var(--color-terracotta-deep); font-variant-numeric: lining-nums tabular-nums; }

  .bcol-cta { margin-top: 1.3rem; align-self: flex-start; font-weight: 600; }

  /* PROMISE: editorial, no filled box. */
  .promise {
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding-top: clamp(1.2rem, 2.5vw, 1.6rem);
    border-top: 1px solid var(--hair-strong);
    font-size: var(--text-base);
    line-height: 1.6;
    color: var(--color-pine-ink);
    max-width: 46rem;
  }
  .promise :global(strong) { color: var(--color-pine); font-weight: 600; }

  @media (min-width: 920px) {
    .pricing-body { grid-template-columns: 0.92fr 1.08fr; gap: clamp(3rem, 6vw, 5rem); }
  }
</style>
