---
import { useT, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).pricing;
---

<section id="pricing" class="section pricing">
  <div class="wrap">
    <header class="pricing-head" data-reveal>
      <p class="label">{t.label}</p>
      <h2 class="display-l pricing-title" set:html={t.headingHtml} />
      <p class="lead prose pricing-lead">{t.lead}</p>
    </header>

    <div class="pricing-body">
      <div class="membership" data-reveal>
        <p class="label membership-label">{t.membershipLabel}</p>
        <p class="price"><span class="price-amt">{t.price}</span><span class="price-per">{t.per}</span></p>
        <p class="price-tag">{t.tag}</p>

        <ul class="incl">
          {
            t.included.map((it) => (
              <li>
                <svg class="tick" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.8" aria-hidden="true">
                  <path d="m5 10.5 3.2 3L15 6.5" stroke-linecap="round" stroke-linejoin="round" />
                </svg>
                <span>{it}</span>
              </li>
            ))
          }
        </ul>

        <p class="membership-foot">{t.membershipFoot}</p>
        <a href="tel:+19412506561" class="btn btn-primary membership-cta">
          <span aria-hidden="true">&#9742;</span> {t.cta}
        </a>
      </div>

      <div class="standalone">
        <div class="block" data-reveal style="transition-delay:80ms">
          <h3 class="block-title display-s">{t.fmTitle}</h3>
          <p class="block-intro">{t.fmIntro}</p>
          <ul class="rate-list">
            {
              t.rates.map((r) => (
                <li class="rate">
                  <span class="rate-name">{r.name}<em>{r.detail}</em></span>
                  <span class="rate-price">{r.price}</span>
                </li>
              ))
            }
          </ul>
        </div>

        <div class="block" data-reveal style="transition-delay:160ms">
          <h3 class="block-title display-s">{t.weightTitle}</h3>
          <p class="block-intro">{t.weightIntro}</p>
          <p class="block-note">{t.weightNote}</p>
        </div>
      </div>
    </div>

    <p class="promise" data-reveal set:html={t.promiseHtml} />
  </div>
</section>

<style>
  .pricing { background: var(--color-cream); }
  .pricing-head { max-width: 50rem; }
  .pricing-title { margin: 1.1rem 0 0; }
  .pricing-title :global(em) { font-style: italic; color: var(--color-terracotta-deep); }
  .pricing-lead { margin-top: 1.3rem; }

  .pricing-body {
    margin-top: clamp(2.75rem, 6vw, 4.5rem);
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2rem, 4vw, 3.5rem);
    align-items: start;
  }

  .membership {
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    background: color-mix(in srgb, #fff 45%, var(--color-cream));
    padding: clamp(2rem, 4vw, 2.85rem);
  }
  .membership-label { color: var(--color-sage-deep); }
  .price { margin: 1rem 0 0; display: flex; align-items: baseline; gap: 0.5rem; }
  .price-amt { font-family: var(--font-display); font-weight: 500; font-size: clamp(3.5rem, 7vw, 5rem); line-height: 0.9; color: var(--color-pine); font-variant-numeric: lining-nums tabular-nums; letter-spacing: -0.02em; }
  .price-per { font-size: 1.05rem; color: var(--color-pine-ink); }
  .price-tag { margin: 0.45rem 0 0; color: var(--color-pine-ink); }

  .incl { list-style: none; margin: 1.75rem 0 0; padding: 1.75rem 0 0; border-top: 1px solid var(--hair); display: grid; gap: 0.8rem; }
  .incl li { display: flex; gap: 0.7rem; align-items: flex-start; color: var(--color-pine-ink); font-size: var(--text-sm); }
  .tick { width: 1.15rem; height: 1.15rem; flex: 0 0 auto; color: var(--color-terracotta); margin-top: 0.15rem; }

  .membership-foot { margin: 1.5rem 0 0; font-size: var(--text-sm); color: var(--color-pine-ink); opacity: 0.85; line-height: 1.6; }
  .membership-cta { margin-top: 1.4rem; width: 100%; justify-content: center; }

  .standalone { display: grid; gap: clamp(1.75rem, 3.5vw, 2.5rem); align-content: start; }
  .block { padding-top: 1.4rem; border-top: 1px solid var(--hair); }
  .block-title { margin: 0; color: var(--color-pine); }
  .block-intro { margin: 0.7rem 0 0; color: var(--color-pine-ink); font-size: var(--text-sm); line-height: 1.6; }

  .rate-list { list-style: none; margin: 1.3rem 0 0; padding: 0; }
  .rate { display: flex; justify-content: space-between; align-items: baseline; gap: 1.5rem; padding: 0.95rem 0; border-bottom: 1px solid var(--hair); }
  .rate-name { display: flex; flex-direction: column; font-weight: 600; color: var(--color-pine); }
  .rate-name em { font-style: normal; font-weight: 400; font-size: var(--text-sm); color: var(--color-pine-ink); opacity: 0.75; margin-top: 0.15rem; }
  .rate-price { font-family: var(--font-display); font-weight: 500; font-size: 1.6rem; color: var(--color-terracotta-deep); font-variant-numeric: lining-nums tabular-nums; }

  .block-note { margin: 1.1rem 0 0; font-size: var(--text-sm); line-height: 1.6; color: var(--color-pine-ink); }

  .promise {
    margin: clamp(2rem, 4vw, 3rem) 0 0;
    padding: clamp(1.1rem, 2.5vw, 1.5rem) clamp(1.25rem, 3vw, 1.75rem);
    border: 1px solid color-mix(in srgb, var(--color-terracotta) 30%, var(--hair));
    border-left: 3px solid var(--color-terracotta);
    border-radius: var(--radius);
    background: color-mix(in srgb, var(--color-terracotta) 6%, var(--color-cream));
    font-size: var(--text-lead);
    line-height: 1.5;
    color: var(--color-pine-ink);
    max-width: 46rem;
  }
  .promise :global(strong) { color: var(--color-pine); font-weight: 700; }

  @media (min-width: 920px) {
    .pricing-body { grid-template-columns: 0.95fr 1.05fr; gap: clamp(3rem, 6vw, 5rem); }
  }
</style>
