---
const steps = [
  {
    title: 'Reach out',
    body: 'Call or email Liz. You can ask questions, share what you are looking for, and find out whether primary care, functional medicine, or weight care is the right fit.',
  },
  {
    title: 'Talk it through',
    body: 'You will talk through your health history, current concerns, goals, and care options. If a service has a separate cost, you will know the price before care begins.',
  },
  {
    title: 'Begin care',
    body: 'Start with the service that fits your needs. You may choose ongoing primary care membership, a functional medicine visit, or standalone weight care.',
  },
];
---

<section id="how" class="section how">
  <div class="wrap how-grid">
    <div class="how-head" data-reveal>
      <h2 class="display-l how-title">Starting care is a&nbsp;conversation.</h2>
      <p class="how-foot prose">
        Telehealth is available for adults 18 and older who are located in Florida at the time
        of each visit. Sarasota and Lakewood Ranch in-person care is planned.
      </p>
    </div>

    <div class="how-steps">
      {
        steps.map((s, i) => (
          <div class="how-step" data-reveal style={`transition-delay:${i * 90}ms`}>
            <h3 class="how-step-title display-s">{s.title}</h3>
            <p class="how-step-body">{s.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .how { background: var(--color-cream-soft); }
  .how-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(2.5rem, 5vw, 4rem);
    align-items: start;
  }
  .how-title { max-width: 12ch; }
  .how-foot { margin: 1.5rem 0 0; font-size: var(--text-sm); color: var(--color-pine-ink); }

  .how-steps { display: grid; gap: 0; }
  .how-step { padding: clamp(1.5rem, 3vw, 2rem) 0; border-top: 1px solid var(--hair); }
  .how-step:last-child { border-bottom: 1px solid var(--hair); }
  .how-step-title { margin: 0; color: var(--color-pine); }
  .how-step-body { margin: 0.5rem 0 0; color: var(--color-pine-ink); max-width: 40rem; }

  @media (min-width: 900px) {
    .how-grid { grid-template-columns: 0.9fr 1.1fr; gap: clamp(3rem, 6vw, 5rem); }
  }
</style>
