---
import { Image } from 'astro:assets';
import portrait from '../assets/liz-portrait.png';
import { useT, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).about;
---

<section id="about" class="section about">
  <div class="wrap">
    <header class="about-head" data-reveal>
      <h2 class="display-l about-title">{t.heading}</h2>
      <p class="lead prose about-lead">{t.lead}</p>
    </header>

    <ul class="providers is-single">
      <li class="provider" data-reveal>
        <figure class="provider-figure">
          <Image
            src={portrait}
            alt={`${t.name}, ${t.credentials}`}
            widths={[360, 560, 720]}
            sizes="(min-width: 880px) 23rem, 80vw"
            class="provider-media"
          />
        </figure>
        <div class="provider-body">
          <p class="label provider-cred">{t.credentials}</p>
          <h3 class="provider-name display-m">{t.name}</h3>
          <p class="provider-meta">
            {t.meta.map((m, i) => (
              <>
                {i > 0 && <span class="provider-dot" aria-hidden="true">/</span>}
                <span>{m}</span>
              </>
            ))}
          </p>
          {t.bio.map((para) => <p class="provider-para">{para}</p>)}
          <p class="provider-quote">{t.quote}</p>
        </div>
      </li>
    </ul>
  </div>
</section>

<style>
  .about { background: var(--color-cream-soft); }
  .about-head { max-width: 44rem; }
  .about-lead { margin-top: 1.3rem; }

  .providers { list-style: none; margin: clamp(2.75rem, 6vw, 4.5rem) 0 0; padding: 0; display: grid; gap: 2.5rem; }

  .provider { display: grid; grid-template-columns: 1fr; gap: clamp(1.75rem, 4vw, 3rem); align-items: start; }

  .provider-figure {
    margin: 0;
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    overflow: hidden;
    background: radial-gradient(120% 100% at 50% 0%, var(--color-cream) 0%, var(--color-sage-wash) 100%);
    aspect-ratio: 4 / 5;
    max-width: 23rem;
  }
  .provider-media { width: 100%; height: 100%; object-fit: cover; object-position: 50% 16%; display: block; }

  .provider-cred { color: var(--color-terracotta-deep); margin: 0; }
  .provider-name { margin: 0.5rem 0 0; }
  .provider-meta {
    margin: 0.8rem 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-sage-deep);
  }
  .provider-dot { color: var(--color-terracotta); }
  .provider-para { margin: 0 0 1rem; color: var(--color-pine-ink); max-width: 40rem; }
  .provider-quote {
    margin: 1.4rem 0 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--color-terracotta);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: var(--display-s);
    line-height: 1.3;
    color: var(--color-pine);
    max-width: 30rem;
  }

  @media (min-width: 880px) {
    .is-single .provider { grid-template-columns: 23rem 1fr; gap: clamp(3rem, 6vw, 5rem); }
    .is-single .provider-body { padding-top: 0.5rem; }
  }
</style>
