---
import { Image } from 'astro:assets';
import portrait from '../assets/liz-portrait.png';

// Modular: add entries to `providers` and the layout becomes a grid, no
// rebrand needed. The (deferred) living-portrait video lives on the figure.
const providers = [
  {
    name: 'Elizabeth Hanke',
    credentials: 'APRN, FNP-BC',
    photo: portrait,
    meta: ['Autonomous Florida APRN', 'Women’s health', 'Functional medicine'],
    bio: [
      'Liz is an autonomous Florida nurse practitioner and the founder of Primary Care and Beyond. She created the practice to offer care that feels personal, thoughtful, and honest about cost.',
      'After years in the insurance-driven system, she saw how often patients, especially women, felt rushed or dismissed when their symptoms did not fit a simple answer. Primary Care and Beyond was built for people who want time, context, and a provider who keeps looking with them.',
    ],
    quote: 'The same provider, with time to understand the full picture.',
  },
];

const single = providers.length === 1;
---

<section id="about" class="section about">
  <div class="wrap">
    <header class="about-head" data-reveal>
      <h2 class="display-l about-title">{single ? 'Meet your provider.' : 'Meet your care team.'}</h2>
      <p class="lead prose about-lead">
        Direct care means you work with one provider who knows your history, your goals, and
        what has already been tried.
      </p>
    </header>

    <ul class={`providers ${single ? 'is-single' : ''}`}>
      {
        providers.map((p) => (
          <li class="provider" data-reveal>
            <figure class="provider-figure">
              <Image
                src={p.photo}
                alt={`${p.name}, ${p.credentials}`}
                widths={[360, 560, 720]}
                sizes="(min-width: 880px) 23rem, 80vw"
                class="provider-media"
              />
            </figure>
            <div class="provider-body">
              <p class="label provider-cred">{p.credentials}</p>
              <h3 class="provider-name display-m">{p.name}</h3>
              <p class="provider-meta">
                {p.meta.map((t, i) => (
                  <>
                    {i > 0 && <span class="provider-dot" aria-hidden="true">/</span>}
                    <span>{t}</span>
                  </>
                ))}
              </p>
              {p.bio.map((para) => <p class="provider-para">{para}</p>)}
              <p class="provider-quote">{p.quote}</p>
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .about { background: var(--color-cream-soft); }
  .about-head { max-width: 44rem; }
  .about-lead { margin-top: 1.3rem; }

  .providers { list-style: none; margin: clamp(2.75rem, 6vw, 4.5rem) 0 0; padding: 0; display: grid; gap: 2.5rem; }
  .providers:not(.is-single) { grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr)); }

  .provider { display: grid; grid-template-columns: 1fr; gap: clamp(1.75rem, 4vw, 3rem); align-items: start; }

  .provider-figure {
    margin: 0;
    border: 1px solid var(--hair);
    border-radius: var(--radius);
    box-shadow: var(--shadow-frame);
    overflow: hidden;
    background: radial-gradient(120% 100% at 50% 0%, var(--color-cream) 0%, var(--color-sage-wash) 100%);
    aspect-ratio: 4 / 5;
    max-width: 23rem;
  }
  .provider-media { width: 100%; height: 100%; object-fit: cover; object-position: 50% 16%; display: block; }

  .provider-cred { color: var(--color-terracotta-deep); margin: 0; }
  .provider-name { margin: 0.5rem 0 0; }
  .provider-meta {
    margin: 0.8rem 0 1.5rem;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.6rem;
    font-family: var(--font-body);
    font-weight: 600;
    font-size: var(--text-sm);
    color: var(--color-sage-deep);
  }
  .provider-dot { color: var(--color-terracotta); }
  .provider-para { margin: 0 0 1rem; color: var(--color-pine-ink); max-width: 40rem; }
  .provider-quote {
    margin: 1.4rem 0 0;
    padding-left: 1.1rem;
    border-left: 2px solid var(--color-terracotta);
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 500;
    font-size: var(--display-s);
    line-height: 1.3;
    color: var(--color-pine);
    max-width: 30rem;
  }

  @media (min-width: 880px) {
    .is-single .provider { grid-template-columns: 23rem 1fr; gap: clamp(3rem, 6vw, 5rem); }
    .is-single .provider-body { padding-top: 0.5rem; }
  }
</style>
