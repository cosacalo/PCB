---
import { Image } from 'astro:assets';
import iconCream from '../assets/logo-icon-cream.png';
import { useT, type Lang } from '../i18n';
interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const t = useT(lang).footer;
const year = new Date().getFullYear();
---

<footer class="footer">
  <div class="wrap footer-grid">
    <div class="footer-brand">
      <a href="#top" class="footer-logo" aria-label="Primary Care and Beyond, back to top">
        <Image src={iconCream} alt="" widths={[64, 128]} class="footer-icon" aria-hidden="true" />
        <span class="footer-wordmark">
          <span class="footer-name">Primary Care</span>
          <span class="footer-sub">and Beyond</span>
        </span>
      </a>
      <p class="footer-tag">{t.tagline}</p>
      <p class="footer-pillars" set:html={t.pillars} />
    </div>

    <div class="footer-contact">
      <h3 class="footer-h">{t.getInTouch}</h3>
      <ul>
        <li><span>{t.labels.tel}</span> <a href="tel:+19412221771">941.222.1771</a></li>
        <li><span>{t.labels.fax}</span> <span>941.907.8686</span></li>
        <li><span>{t.labels.email}</span> <a href="mailto:Elizabeth@primarycareandbeyond.com">Elizabeth@primarycareandbeyond.com</a></li>
        <li><span>{t.labels.web}</span> <a href="https://primarycareandbeyond.com">primarycareandbeyond.com</a></li>
      </ul>
    </div>
  </div>

  <div class="wrap footer-legal">
    <p>{t.legal}</p>
    <p class="footer-copy">&copy; {year} Primary Care and Beyond LLC. {t.rights}</p>
  </div>
</footer>

<style>
  .footer { background: var(--color-pine-deep); color: color-mix(in srgb, var(--color-cream) 82%, transparent); padding: clamp(3rem, 6vw, 4.5rem) 0 2.5rem; }
  .footer-grid { display: grid; grid-template-columns: 1fr; gap: 2.5rem; padding-bottom: 2.5rem; border-bottom: 1px solid var(--hair-on-pine); }
  .footer-logo { display: inline-flex; align-items: center; gap: 0.65rem; text-decoration: none; }
  .footer-icon { height: 3rem; width: auto; }
  .footer-wordmark { display: flex; flex-direction: column; line-height: 0.94; }
  .footer-name { font-family: var(--font-display); font-weight: 600; font-size: 1.55rem; color: var(--color-cream); }
  .footer-sub { font-family: var(--font-display); font-style: italic; font-weight: 500; font-size: 1.1rem; color: var(--color-sage-light); }
  .footer-tag { font-family: var(--font-display); font-size: 1.3rem; font-style: italic; color: var(--color-cream); margin: 1rem 0 0.6rem; }
  .footer-pillars { margin: 0; font-size: 0.82rem; letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-sage-light); }

  .footer-h { color: var(--color-cream); font-family: var(--font-body); font-weight: 600; font-size: var(--text-label); letter-spacing: 0.18em; text-transform: uppercase; margin: 0 0 1rem; }
  .footer-contact ul { list-style: none; margin: 0; padding: 0; display: grid; gap: 0.6rem; }
  .footer-contact li { display: flex; gap: 0.75rem; }
  .footer-contact li span:first-child { flex: 0 0 2.75rem; color: var(--color-sage); font-size: 0.85rem; text-transform: uppercase; letter-spacing: 0.08em; padding-top: 1px; }
  .footer-contact a { color: color-mix(in srgb, var(--color-cream) 88%, transparent); text-decoration: none; min-width: 0; overflow-wrap: anywhere; }
  .footer-contact a:hover { color: var(--color-cream); text-decoration: underline; text-decoration-color: var(--color-terracotta); }

  .footer-legal { padding-top: 2rem; }
  .footer-legal p { margin: 0; font-size: 0.82rem; line-height: 1.6; color: color-mix(in srgb, var(--color-cream) 58%, transparent); max-width: 60rem; }
  .footer-copy { margin-top: 1rem !important; }

  @media (min-width: 780px) { .footer-grid { grid-template-columns: 1.4fr 1fr; align-items: start; } }
</style>
