---
const points = [
  {
    title: 'One provider who knows you',
    body: 'The same nurse practitioner every visit, who remembers your history, your goals, and your life. No rotating faces, no starting over each time.',
  },
  {
    title: 'Transparent, flat-fee pricing',
    body: 'One clear membership price, posted right here. No copays, no surprise bills, and an estimate before any added care. You always know the cost first.',
  },
  {
    title: 'Care beyond the prescription pad',
    body: 'Time to look for the root cause, not just write a script and move on. Primary care, functional medicine, and weight care under one roof.',
  },
];
---

<section id="approach" class="section approach">
  <div class="wrap">
    <div class="approach-head" data-reveal>
      <p class="eyebrow approach-eyebrow">The difference</p>
      <h2 class="display-l">Beyond the seven-minute visit.</h2>
      <p class="approach-lead prose-measure">
        Conventional primary care is built around volume: short visits, long waits, and a
        different provider each time. Primary Care and Beyond is built around you. It is a
        direct membership, so the time you get is real time, and the relationship is the
        point.
      </p>
    </div>

    <ul class="approach-grid">
      {
        points.map((p, i) => (
          <li class="approach-card" data-reveal style={`transition-delay:${i * 70}ms`}>
            <span class="approach-num">{String(i + 1).padStart(2, '0')}</span>
            <h3 class="approach-card-title">{p.title}</h3>
            <p class="approach-card-body">{p.body}</p>
          </li>
        ))
      }
    </ul>
  </div>
</section>

<style>
  .approach-eyebrow { color: var(--color-sage-deep); margin-bottom: 1rem; }
  .approach-lead {
    margin-top: 1.4rem;
    font-size: 1.15rem;
    color: var(--color-pine-ink);
  }

  .approach-grid {
    list-style: none;
    margin: clamp(2.5rem, 5vw, 3.5rem) 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }
  .approach-card {
    background: var(--color-cream);
    border: 1px solid color-mix(in srgb, var(--color-tan) 45%, transparent);
    border-radius: var(--radius-card);
    padding: 2rem 1.85rem;
  }
  .approach-num {
    font-family: var(--font-display);
    font-size: 1.5rem;
    color: var(--color-terracotta);
    font-weight: 600;
  }
  .approach-card-title {
    margin: 0.7rem 0 0.6rem;
    font-size: 1.5rem;
  }
  .approach-card-body { margin: 0; color: var(--color-pine-ink); }

  @media (min-width: 760px) {
    .approach-grid { grid-template-columns: repeat(3, 1fr); }
  }
</style>
