---
import '../styles/global.css';
import { useT, routes, locales, type Lang } from '../i18n';
import MobileCallBar from '../components/MobileCallBar.astro';

interface Props { lang?: Lang; title?: string; description?: string }
const { lang = 'en', title: titleProp, description: descriptionProp } = Astro.props;
const meta = useT(lang).meta;
const title = titleProp ?? meta.title;
const description = descriptionProp ?? meta.description;

const canonical = new URL(Astro.url.pathname, Astro.site);
// Normalize base so paths work whether BASE_URL is '/PCB', '/PCB/', or '/'.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ogImage = new URL(`${base}/og-image.png`, Astro.site);

// Structured-data graph: the practice (MedicalBusiness), the provider (Person),
// and the website, cross-linked by @id so engines resolve one entity. Telehealth
// statewide today, so areaServed is the State of Florida with no street address;
// add per-location LocalBusiness once the Sarasota / Lakewood Ranch offices open.
// `sameAs` (NPI registry, Google Business Profile, LinkedIn) to be added once
// those public profiles exist; they materially help AI engines corroborate us.
const siteOrigin = Astro.site ? Astro.site.origin : 'https://www.primarycareandbeyond.com';
const logoUrl = new URL(`${base}/favicon-512.png`, Astro.site).href;
const orgId = `${siteOrigin}/#practice`;
const providerId = `${siteOrigin}/#provider`;

const practiceLd = {
  '@type': 'MedicalBusiness',
  '@id': orgId,
  name: 'Primary Care and Beyond',
  alternateName: 'Primary Care and Beyond LLC',
  description,
  url: `${siteOrigin}/`,
  telephone: '+1-941-390-3224',
  email: 'Elizabeth@primarycareandbeyond.com',
  image: ogImage.href,
  logo: logoUrl,
  priceRange: '$$',
  slogan: 'Your health, beyond the basics.',
  knowsLanguage: ['en', 'es'],
  availableLanguage: ['English', 'Spanish'],
  areaServed: { '@type': 'State', name: 'Florida' },
  medicalSpecialty: ['PrimaryCare'],
  founder: { '@id': providerId },
  employee: { '@id': providerId },
  contactPoint: {
    '@type': 'ContactPoint',
    telephone: '+1-941-390-3224',
    email: 'Elizabeth@primarycareandbeyond.com',
    contactType: 'customer service',
    areaServed: 'US-FL',
    availableLanguage: ['English', 'Spanish'],
  },
  makesOffer: [
    {
      '@type': 'Offer',
      name: 'Primary care membership',
      category: 'Telehealth direct primary care',
      priceCurrency: 'USD',
      price: '175',
      description:
        "Monthly telehealth primary care membership for adults in Florida. Includes preventive care, chronic condition support, women's health, non-controlled prescriptions and refills, lab orders when indicated, care coordination, and messaging between visits.",
    },
    {
      '@type': 'Offer',
      name: 'Weight care membership',
      category: 'Medical weight care',
      priceCurrency: 'USD',
      price: '150',
      description:
        'Monthly telehealth medical weight care membership: health history, lab review, lifestyle planning, and GLP-1 medication management when appropriate. Available on its own or bundled with primary care for $300 per month.',
    },
    {
      '@type': 'Offer',
      name: 'Primary care and weight care bundle',
      category: 'Telehealth membership bundle',
      priceCurrency: 'USD',
      price: '300',
      description:
        'The primary care and weight care memberships together for $300 per month, saving $25 versus joining each separately.',
    },
    {
      '@type': 'Offer',
      name: 'Functional medicine consultation',
      category: 'Functional medicine',
      priceCurrency: 'USD',
      price: '375',
      description:
        'Root-cause functional medicine, billed per visit and quoted before care. Initial consultation 90 minutes ($375), follow-up ($200), extended follow-up ($300), and lab review ($150).',
    },
  ],
};

const providerLd = {
  '@type': 'Person',
  '@id': providerId,
  name: 'Elizabeth Hanke',
  honorificSuffix: 'APRN, FNP-BC',
  jobTitle: 'Autonomous Nurse Practitioner',
  worksFor: { '@id': orgId },
  knowsLanguage: ['en', 'es'],
  knowsAbout: [
    'Primary care',
    'Functional medicine',
    'Medical weight care',
    "Women's health",
    'Chronic disease management',
  ],
  hasCredential: [
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'Advanced Practice Registered Nurse (APRN)' },
    { '@type': 'EducationalOccupationalCredential', credentialCategory: 'Board-certified Family Nurse Practitioner (FNP-BC)' },
  ],
};

const websiteLd = {
  '@type': 'WebSite',
  '@id': `${siteOrigin}/#website`,
  name: 'Primary Care and Beyond',
  url: `${siteOrigin}/`,
  inLanguage: lang === 'es' ? 'es' : 'en',
  publisher: { '@id': orgId },
};

const graphLd = { '@context': 'https://schema.org', '@graph': [practiceLd, providerLd, websiteLd] };
const skip = lang === 'es' ? 'Saltar al contenido' : 'Skip to content';
const fontCss = `
@font-face{font-family:'Cormorant Garamond';src:url('${base}/fonts/CormorantGaramond.woff2') format('woff2');font-weight:300 700;font-style:normal;font-display:swap}
@font-face{font-family:'Cormorant Garamond';src:url('${base}/fonts/CormorantGaramond-Italic.woff2') format('woff2');font-weight:300 700;font-style:italic;font-display:swap}
@font-face{font-family:'Source Sans 3';src:url('${base}/fonts/SourceSans3.woff2') format('woff2');font-weight:300 700;font-style:normal;font-display:swap}
`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="robots" content="index, follow, max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
    <meta name="author" content="Elizabeth Hanke, APRN, FNP-BC" />
    <meta name="theme-color" content="#33402a" />
    <link rel="canonical" href={canonical} />

    {locales.map((loc) => (
      <link rel="alternate" hreflang={loc} href={new URL(routes[loc], Astro.site)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(routes.en, Astro.site)} />

    <link rel="icon" href={`${base}/favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" href={`${base}/favicon-32.png`} sizes="32x32" />
    <link rel="apple-touch-icon" href={`${base}/favicon-180.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Primary Care and Beyond" />
    <meta property="og:locale" content={lang === 'es' ? 'es_US' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="Primary Care and Beyond: telehealth primary care, functional medicine, and weight care in Florida." />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(graphLd)} />

    <Fragment set:html={`<style>${fontCss}</style>`} />

    <link rel="preload" href={`${base}/fonts/CormorantGaramond.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/SourceSans3.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/CormorantGaramond-Italic.woff2`} as="font" type="font/woff2" crossorigin />

    <!-- Gate initial hidden states so no-JS / reduced-motion never see a blank page -->
    <script is:inline>
      try {
        // Reloads start at the top (not the restored scroll position) so the
        // brand intro replays on reload. Deep links to #sections still jump and
        // correctly skip the intro (it only runs at scrollY < 4 with no hash).
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('anim-ready');
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-pine focus:px-4 focus:py-2 focus:text-cream"
      >{skip}</a
    >
    <slot />
    <MobileCallBar lang={lang} />
    <div class="grain" aria-hidden="true"></div>

    <script src="../scripts/motion.js"></script>

    {import.meta.env.PROD && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon='{"token": "48a64c28db5044f0b5a1d464ba504df3"}'
      ></script>
    )}
  </body>
</html>
