---
import '../styles/global.css';
import { useT, routes, locales, type Lang } from '../i18n';
import MobileCallBar from '../components/MobileCallBar.astro';

interface Props { lang?: Lang }
const { lang = 'en' } = Astro.props;
const meta = useT(lang).meta;
const title = meta.title;
const description = meta.description;

const canonical = new URL(Astro.url.pathname, Astro.site);
// Normalize base so paths work whether BASE_URL is '/PCB', '/PCB/', or '/'.
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const ogImage = new URL(`${base}/og-image.png`, Astro.site);

// MedicalBusiness structured data. Telehealth statewide today, so areaServed is
// the State of Florida with no street address; add per-location LocalBusiness
// once the Sarasota / Lakewood Ranch offices physically open.
const businessLd = {
  '@context': 'https://schema.org',
  '@type': 'MedicalBusiness',
  name: 'Primary Care and Beyond',
  description,
  url: canonical.href,
  telephone: '+1-941-250-6561',
  email: 'Elizabeth@primarycareandbeyond.com',
  image: ogImage.href,
  logo: new URL(`${base}/favicon-512.png`, Astro.site).href,
  priceRange: '$$',
  knowsLanguage: ['en', 'es'],
  areaServed: { '@type': 'State', name: 'Florida' },
  medicalSpecialty: 'PrimaryCare',
  founder: {
    '@type': 'Person',
    name: 'Elizabeth Hanke',
    honorificSuffix: 'APRN, FNP-BC',
    jobTitle: 'Nurse Practitioner',
  },
};
const skip = lang === 'es' ? 'Saltar al contenido' : 'Skip to content';
const fontCss = `
@font-face{font-family:'Cormorant Garamond';src:url('${base}/fonts/CormorantGaramond.woff2') format('woff2');font-weight:300 700;font-style:normal;font-display:swap}
@font-face{font-family:'Cormorant Garamond';src:url('${base}/fonts/CormorantGaramond-Italic.woff2') format('woff2');font-weight:300 700;font-style:italic;font-display:swap}
@font-face{font-family:'Source Sans 3';src:url('${base}/fonts/SourceSans3.woff2') format('woff2');font-weight:300 700;font-style:normal;font-display:swap}
`;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    {locales.map((loc) => (
      <link rel="alternate" hreflang={loc} href={new URL(routes[loc], Astro.site)} />
    ))}
    <link rel="alternate" hreflang="x-default" href={new URL(routes.en, Astro.site)} />

    <link rel="icon" href={`${base}/favicon.ico`} sizes="any" />
    <link rel="icon" type="image/png" href={`${base}/favicon-32.png`} sizes="32x32" />
    <link rel="apple-touch-icon" href={`${base}/favicon-180.png`} />

    <meta property="og:type" content="website" />
    <meta property="og:locale" content={lang === 'es' ? 'es_US' : 'en_US'} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:url" content={canonical} />
    <meta name="twitter:card" content="summary_large_image" />

    <script type="application/ld+json" is:inline set:html={JSON.stringify(businessLd)} />

    <Fragment set:html={`<style>${fontCss}</style>`} />

    <link rel="preload" href={`${base}/fonts/CormorantGaramond.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/SourceSans3.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}/fonts/CormorantGaramond-Italic.woff2`} as="font" type="font/woff2" crossorigin />

    <!-- Gate initial hidden states so no-JS / reduced-motion never see a blank page -->
    <script is:inline>
      try {
        // Reloads start at the top (not the restored scroll position) so the
        // brand intro replays on reload. Deep links to #sections still jump and
        // correctly skip the intro (it only runs at scrollY < 4 with no hash).
        if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
        if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('anim-ready');
        }
      } catch (e) {}
    </script>
  </head>
  <body>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:absolute focus:left-4 focus:top-4 focus:z-50 focus:rounded focus:bg-pine focus:px-4 focus:py-2 focus:text-cream"
      >{skip}</a
    >
    <slot />
    <MobileCallBar lang={lang} />
    <div class="grain" aria-hidden="true"></div>

    <script src="../scripts/motion.js"></script>

    {import.meta.env.PROD && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon='{"token": "7c376a26eaec422f9a2e49ca32f83341"}'
      ></script>
    )}
  </body>
</html>
